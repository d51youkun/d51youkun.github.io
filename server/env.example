# 同期サーバー (Render 等) の環境変数に設定してください
# ローカル開発: cp .env.example .env して値を入力

ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password

MODERATOR_EMAIL=moderator@example.com
MODERATOR_PASSWORD=moderator-password

# 永続化用（推奨・無料）: Upstash (https://upstash.com) で Redis を作成し、
# REST API の値をここに入れる。未設定ならローカルファイルに保存されるが、
# Renderの無料プランはインスタンスが再起動するたびにファイルが消えるので注意。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
